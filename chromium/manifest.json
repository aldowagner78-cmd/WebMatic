{
  "manifest_version": 3,
  "name": "WebMatic",
  "version": "0.1.0",
  "description": "Automatizacion web modular — Chrome y Edge.",
  "icons": {
    "16": "logo16.png",
    "32": "logo32.png",
    "48": "logo48.png",
    "128": "logo128.png"
  },
  "action": {
    "default_title": "WebMatic",
    "default_icon": {
      "16": "logo16.png",
      "32": "logo32.png",
      "48": "logo48.png"
    }
  },
  "background": {
    "service_worker": "chromium/background.chromium.js"
  },
  "permissions": [
    "storage",
    "downloads",
    "activeTab",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "all_frames": true,
      "js": [
        "src/core/contracts.js",
        "src/core/store.js",
        "src/core/utils.js",
        "src/modules/docking/geometry-manager.js",
        "src/modules/ui/ui-shell.js",
        "src/modules/editor/step-editor.js",
        "src/modules/recorder/recorder.js",
        "src/modules/inventory/page-inventory.js",
        "src/modules/player/player.js",
        "src/modules/storage/iim-adapter.js",
        "src/modules/storage/macro-json.js",
        "src/modules/storage/full-backup.js",
        "src/modules/settings/settings-manager.js",
        "src/modules/controls/genexus-autocomplete.js",
        "src/content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "logo48.png",
        "src/modules/ui/ui-shell.css",
        "src/help/help.html",
        "src/help/help.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": false
  }
}