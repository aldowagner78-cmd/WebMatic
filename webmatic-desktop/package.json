{
  "name": "webmatic-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "WebMatic Desktop — version Electron multiplataforma de WebMatic",
  "author": "WebMatic",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:debug": "electron . --enable-logging",
    "test": "playwright test --config=tests/playwright.config.js",
    "test:report": "playwright show-report tests/playwright-report",
    "dist": "npx electron-builder --win --x64",
    "dist:linux": "npx electron-builder --linux --x64"
  },
  "build": {
    "appId": "com.webmatic.desktop",
    "productName": "WebMatic Desktop",
    "copyright": "Copyright © 2026 WebMatic",
    "directories": {
      "output": "dist-installer"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "src/**/*",
      "!src/**/*.test.*",
      "!tests/**",
      "!test-results/**",
      "!*.bat",
      "!*.vbs"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WebMatic Desktop"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "electron": "^32.0.0",
    "electron-builder": "^26.8.1"
  }
}
