{
  "name": "webmatic",
  "version": "0.1.0",
  "private": true,
  "description": "WebMatic V1 scaffold modular para Firefox Windows",
  "scripts": {
    "test": "node --test accesorios/pruebas/tests/unit/*.test.js",
    "test:watch": "node --test --watch accesorios/pruebas/tests/unit/*.test.js",
    "test:e2e": "node accesorios/pruebas/tests/e2e/iapos-safe/run.js",
    "test:e2e:legacy": "node accesorios/pruebas/tests/e2e/run.js",
    "test:e2e:fixtures": "node accesorios/pruebas/tests/e2e/fixtures-flow/run.js",
    "test:e2e:angular-material": "node accesorios/pruebas/tests/e2e/angular-material-selectors/run.js",
    "test:e2e:flyer-wizard": "node accesorios/pruebas/tests/e2e/flyer-wizard/run.js",
    "test:e2e:universal-resolution": "node accesorios/pruebas/tests/e2e/universal-resolution/run.js",
    "test:e2e:wait-for-navigate": "node accesorios/pruebas/tests/e2e/wait-for-after-navigate/run.js",
    "test:e2e:loop-navigate": "node accesorios/pruebas/tests/e2e/loop-navigate/run.js",
    "test:e2e:extension": "node accesorios/pruebas/tests/e2e/webmatic-extension-safe/run.js",
    "test:e2e:tabs-floating": "node accesorios/pruebas/tests/e2e/webmatic-extension-safe/tabs-floating-run.js",
    "test:e2e:firefox-extension": "node accesorios/pruebas/tests/e2e/firefox-extension-safe/run.js",
    "test:phase1:export-routes": "npm test",
    "verify:v2:firefox:fast": "node accesorios/herramientas/tools/verify-v2-firefox.cjs fast",
    "verify:v2:firefox:full": "node accesorios/herramientas/tools/verify-v2-firefox.cjs full",
    "extract:iapos": "node accesorios/herramientas/tools/extract-iapos-genexus-catalogs.cjs",
    "build:chromium": "node accesorios/herramientas/tools/build-chromium-unpacked.cjs"
  },
  "devDependencies": {
    "happy-dom": "^20.9.0",
    "playwright": "^1.60.0"
  }
}
